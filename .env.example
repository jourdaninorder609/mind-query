# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# MCP Server URLs — configure the databases you want to use.
# Leave blank to use built-in Demo mode (SQLite in-memory).
MONGODB_MCP_URL=http://localhost:3100
POSTGRES_MCP_URL=http://localhost:3101
SQLSERVER_MCP_URL=http://localhost:3102
MYSQL_MCP_URL=http://localhost:3103

# Optional: MongoDB database name for list_collections
MONGODB_DATABASE=mydb

# Optional: SQL Server default schema
SQLSERVER_SCHEMA=dbo
